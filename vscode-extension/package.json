{
  "name": "gwd",
  "displayName": "GWD",
  "description": "VS Code integration for the GWD coding agent",
  "publisher": "FluxLabs",
  "version": "0.0.1",
  "icon": "logo.jpg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rayliu-factory/gwd.git"
  },
  "homepage": "https://github.com/rayliu-factory/gwd#readme",
  "bugs": {
    "url": "https://github.com/rayliu-factory/gwd/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "gwd",
    "chat",
    "automation",
    "claude",
    "openai",
    "llm"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gwd.start",
        "title": "GWD: Start Agent"
      },
      {
        "command": "gwd.stop",
        "title": "GWD: Stop Agent"
      },
      {
        "command": "gwd.newSession",
        "title": "GWD: New Session"
      },
      {
        "command": "gwd.sendMessage",
        "title": "GWD: Send Message"
      },
      {
        "command": "gwd.cycleModel",
        "title": "GWD: Cycle Model"
      },
      {
        "command": "gwd.cycleThinking",
        "title": "GWD: Cycle Thinking Level"
      },
      {
        "command": "gwd.compact",
        "title": "GWD: Compact Context"
      },
      {
        "command": "gwd.abort",
        "title": "GWD: Abort Current Operation"
      },
      {
        "command": "gwd.exportHtml",
        "title": "GWD: Export Conversation as HTML"
      },
      {
        "command": "gwd.sessionStats",
        "title": "GWD: Show Session Stats"
      },
      {
        "command": "gwd.runBash",
        "title": "GWD: Run Bash Command"
      },
      {
        "command": "gwd.switchModel",
        "title": "GWD: Switch Model"
      },
      {
        "command": "gwd.setThinking",
        "title": "GWD: Set Thinking Level"
      },
      {
        "command": "gwd.steer",
        "title": "GWD: Steer Agent"
      },
      {
        "command": "gwd.listCommands",
        "title": "GWD: List Available Commands"
      },
      {
        "command": "gwd.toggleAutoRetry",
        "title": "GWD: Toggle Auto-Retry"
      },
      {
        "command": "gwd.abortRetry",
        "title": "GWD: Abort Retry"
      },
      {
        "command": "gwd.setSessionName",
        "title": "GWD: Set Session Name"
      },
      {
        "command": "gwd.copyLastResponse",
        "title": "GWD: Copy Last Response"
      },
      {
        "command": "gwd.switchSession",
        "title": "GWD: Switch Session"
      },
      {
        "command": "gwd.refreshSessions",
        "title": "GWD: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "gwd.clearFileDecorations",
        "title": "GWD: Clear File Decorations"
      },
      {
        "command": "gwd.showHistory",
        "title": "GWD: Show Conversation History"
      },
      {
        "command": "gwd.askAboutSymbol",
        "title": "GWD: Ask About Symbol"
      },
      {
        "command": "gwd.clearActivity",
        "title": "GWD: Clear Activity Feed",
        "icon": "$(clear-all)"
      },
      {
        "command": "gwd.forkSession",
        "title": "GWD: Fork Session"
      },
      {
        "command": "gwd.toggleSteeringMode",
        "title": "GWD: Toggle Steering Mode"
      },
      {
        "command": "gwd.toggleFollowUpMode",
        "title": "GWD: Toggle Follow-Up Mode"
      },
      {
        "command": "gwd.refactorSymbol",
        "title": "GWD: Refactor Symbol"
      },
      {
        "command": "gwd.findBugsSymbol",
        "title": "GWD: Find Bugs in Symbol"
      },
      {
        "command": "gwd.generateTestsSymbol",
        "title": "GWD: Generate Tests for Symbol"
      },
      {
        "command": "gwd.acceptAllChanges",
        "title": "GWD: Accept All Agent Changes",
        "icon": "$(check-all)"
      },
      {
        "command": "gwd.discardAllChanges",
        "title": "GWD: Discard All Agent Changes",
        "icon": "$(discard)"
      },
      {
        "command": "gwd.acceptFileChanges",
        "title": "Accept Changes",
        "icon": "$(check)"
      },
      {
        "command": "gwd.discardFileChanges",
        "title": "Discard Changes",
        "icon": "$(discard)"
      },
      {
        "command": "gwd.restoreCheckpoint",
        "title": "GWD: Restore Checkpoint"
      },
      {
        "command": "gwd.fixProblemsInFile",
        "title": "GWD: Fix Problems in File"
      },
      {
        "command": "gwd.fixAllProblems",
        "title": "GWD: Fix All Problems"
      },
      {
        "command": "gwd.clearDiagnostics",
        "title": "GWD: Clear Agent Diagnostics"
      },
      {
        "command": "gwd.commitAgentChanges",
        "title": "GWD: Commit Agent Changes"
      },
      {
        "command": "gwd.createAgentBranch",
        "title": "GWD: Create Branch for Agent Work"
      },
      {
        "command": "gwd.showAgentDiff",
        "title": "GWD: Show Agent Diff"
      },
      {
        "command": "gwd.clearPlan",
        "title": "GWD: Clear Plan View",
        "icon": "$(clear-all)"
      },
      {
        "command": "gwd.cycleApprovalMode",
        "title": "GWD: Cycle Approval Mode"
      },
      {
        "command": "gwd.selectApprovalMode",
        "title": "GWD: Select Approval Mode"
      }
    ],
    "keybindings": [
      {
        "command": "gwd.newSession",
        "key": "ctrl+shift+g ctrl+shift+n",
        "mac": "cmd+shift+g cmd+shift+n"
      },
      {
        "command": "gwd.cycleModel",
        "key": "ctrl+shift+g ctrl+shift+m",
        "mac": "cmd+shift+g cmd+shift+m"
      },
      {
        "command": "gwd.cycleThinking",
        "key": "ctrl+shift+g ctrl+shift+t",
        "mac": "cmd+shift+g cmd+shift+t"
      },
      {
        "command": "gwd.abort",
        "key": "ctrl+shift+g ctrl+shift+a",
        "mac": "cmd+shift+g cmd+shift+a"
      },
      {
        "command": "gwd.steer",
        "key": "ctrl+shift+g ctrl+shift+i",
        "mac": "cmd+shift+g cmd+shift+i"
      },
      {
        "command": "gwd.sendMessage",
        "key": "ctrl+shift+g ctrl+shift+p",
        "mac": "cmd+shift+g cmd+shift+p"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gwd",
          "title": "GWD",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "gwd": [
        {
          "type": "webview",
          "id": "gwd-sidebar",
          "name": "GWD Agent"
        },
        {
          "id": "gwd-sessions",
          "name": "Sessions"
        },
        {
          "id": "gwd-activity",
          "name": "Activity"
        },
        {
          "id": "gwd-plan",
          "name": "Plan"
        },
        {
          "id": "gwd-checkpoints",
          "name": "Checkpoints"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "gwd.refreshSessions",
          "when": "view == gwd-sessions",
          "group": "navigation"
        },
        {
          "command": "gwd.clearActivity",
          "when": "view == gwd-activity",
          "group": "navigation"
        }
      ],
      "scm/title": [
        {
          "command": "gwd.acceptAllChanges",
          "group": "navigation",
          "when": "scmProvider == gwd"
        },
        {
          "command": "gwd.discardAllChanges",
          "group": "navigation",
          "when": "scmProvider == gwd"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "gwd.acceptFileChanges",
          "group": "inline",
          "when": "scmProvider == gwd"
        },
        {
          "command": "gwd.discardFileChanges",
          "group": "inline",
          "when": "scmProvider == gwd"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "gwd.agent",
        "name": "gwd",
        "fullName": "GWD Agent",
        "description": "GWD coding agent",
        "isSticky": true
      }
    ],
    "configuration": {
      "title": "GWD",
      "properties": {
        "gwd.binaryPath": {
          "type": "string",
          "default": "gwd",
          "description": "Path to the GWD binary"
        },
        "gwd.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the GWD agent when the extension activates"
        },
        "gwd.autoCompaction": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic context compaction"
        },
        "gwd.codeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show 'Ask GWD' code lens above functions and classes"
        },
        "gwd.showProgressNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show progress notification while the agent is working"
        },
        "gwd.activityFeedMaxItems": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 500,
          "description": "Maximum number of items shown in the Activity feed"
        },
        "gwd.showContextWarning": {
          "type": "boolean",
          "default": true,
          "description": "Warn when context window usage exceeds the threshold"
        },
        "gwd.contextWarningThreshold": {
          "type": "number",
          "default": 80,
          "minimum": 50,
          "maximum": 95,
          "description": "Context window usage percentage that triggers a warning"
        },
        "gwd.approvalMode": {
          "type": "string",
          "default": "auto-approve",
          "enum": [
            "auto-approve",
            "ask",
            "plan-only"
          ],
          "enumDescriptions": [
            "Agent runs freely without prompts",
            "Prompt before file changes and commands",
            "Read-only mode — agent can analyze but not modify"
          ],
          "description": "Approval mode for agent actions"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "node --experimental-strip-types --test \"test/*.test.ts\"",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@gwd-build/contracts": "file:../packages/contracts"
  }
}
